APP_NAME=Runholix
POSTGRES_HOST=db:5432
POSTGRES_USER=runholix
POSTGRES_PASSWORD=changeme
POSTGRES_DB=runholix
JWT_SECRET=change-this-to-a-long-random-string
CSRF_SECRET=change-this-to-a-long-random-string
CORS_ORIGIN=http://localhost   # Allowed browser origin for CORS. Use comma-separated values for multiple origins.
VITE_API_URL=/api

# Public URL of your app (used in email links)
APP_URL=http://localhost

# SMTP configuration (leave SMTP_HOST empty to disable email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=tls        # Options: plain, tls (STARTTLS), ssl (TLS/SSL on port 465)
SMTP_USER=user@example.com
SMTP_PASS=yourpassword
SMTP_FROM=Runholix <noreply@example.com>
# Optional SMTP configs
# SMTP_POOL=true  # Default to true, disable  if your SMTP server does not support it
# SMTP_POOL_MAX_CONNECTIONS=3  # Default to 3
# SMTP_POOL_MAX_MESSAGES=100  # Default to 100

# Leave blank to skip admin approval for new accounts
ADMIN_EMAIL=

# Web Push (leave VAPID keys empty to disable push notifications)
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@example.com